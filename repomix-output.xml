    fontSize: tmpl === 'bold' ? '1.6rem' : tmpl === 'noir' ? '1.15rem' : '1.1rem',
    lineHeight: 1.3,
  }

  return (
    <div className={`w-full h-full flex flex-col bg-gradient-to-br ${bgGradient(tmpl)}`}
      style={{ boxShadow: 'inset 0 0 80px rgba(0,0,0,0.35)' }}>
