<file path="src/components/catalog/BotonWhatsApp.tsx">
'use client'

import { useState } from 'react'

export default function BotonWhatsApp({ productoNombre, productoId, productoSlug, idTienda, whatsappNumber, className }: {
  productoNombre: string; productoId: string; productoSlug?: string | null; idTienda: string; whatsappNumber: string; className?: string
}) {
  const [sent, setSent] = useState(false)

  const abrirWhatsApp = () => {
    const num = whatsappNumber.replace(/\D/g, '')
    if (!num) return
    const url = window.location.href
    const msg = encodeURIComponent(`Hola, me interesa este producto: ${productoNombre}. Aquí lo vi: ${url}`)
    window.open(`https://wa.me/${num}?text=${msg}`, '_blank')
    setSent(true)
    setTimeout(() => setSent(false), 2000)
  }

  return (
    <button
      onClick={e => { e.stopPropagation(); abrirWhatsApp() }}
      className={className || "inline-flex items-center gap-1.5 bg-gradient-to-r from-emerald-500 to-emerald-600 text-white text-sm font-medium px-5 py-2.5 rounded-xl hover:from-emerald-600 hover:to-emerald-700 transition-all shadow-lg shadow-emerald-500/25 active:scale-95 press-scale-sm"}
