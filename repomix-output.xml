'use client'

import { useState } from 'react'

export default function ModalCompartirProducto({ productoNombre, tiendaSlug, productoSlug, onClose }: { productoNombre: string; tiendaSlug: string; productoSlug: string; onClose: () => void }) {
  const [copiado, setCopiado] = useState(false)
  const url = `${window.location.origin}/catalogo/${tiendaSlug}/producto/${productoSlug}`
  const waMsg = encodeURIComponent(`Mira este producto: ${productoNombre} - ${url}`)

  const copiar = async () => {
    try {
      await navigator.clipboard.writeText(url)
      setCopiado(true)
      setTimeout(() => setCopiado(false), 2500)
    } catch {
      alert('No se pudo copiar el enlace. Intenta manualmente.')
    }
