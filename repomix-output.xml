import { toPng } from 'html-to-image'
import { PlantillaPreview, ICONOS_ANUNCIO } from '@/components/catalog/CatalogoModal'
import type { CatalogoModalConfig, TemplateKey } from '@/components/catalog/CatalogoModal'
