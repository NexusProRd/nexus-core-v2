.skeleton-shimmer::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 25%, rgba(255,255,255,0.12) 50%, transparent 75%);
  transform: translateX(-100%);
  animation: shimmer 1.5s ease-in-out infinite;
