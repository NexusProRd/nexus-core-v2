  if (typeof themeConfig === 'string') return getPalette(themeConfig)
  if (typeof themeConfig === 'object') {
    const config = themeConfig as Record<string, unknown>
    if (typeof config.palette === 'string') return getPalette(config.palette)
  }
  return PALETTES[0]
}
